# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_DOMAIN=https://your-domain.example.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/careerpass

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_me

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# OAuth portal (legacy / SaaS auth bridge — leave blank in private mode)
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_me
# Override only if you don't want APP_DOMAIN/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# ─── Gmail Pub/Sub Push (real-time main path) ─────────────────────────────────
# Full topic resource name: projects/<gcp-project>/topics/<topic-id>
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/careerpass-gmail-events
GMAIL_PUBSUB_SUBSCRIPTION=careerpass-gmail-events-sub
# OIDC audience the push subscription signs to — must match the Express endpoint
GMAIL_PUBSUB_AUDIENCE=https://your-domain.example.com/api/gmail/push
# Service account whose OIDC token is verified on inbound push
GMAIL_PUBSUB_SERVICE_ACCOUNT=your-pubsub-push-sa@your-project.iam.gserviceaccount.com
GMAIL_WATCH_RENEWAL_CONCURRENCY=3

# ─── Gmail fallback / bootstrap policy ────────────────────────────────────────
# Push is the real-time path. These flags govern controlled fallbacks.
# All default to TRUE if unset; set to "false" to disable the branch.
GMAIL_BACKGROUND_SCAN_ENABLED=true
GMAIL_OAUTH_BOOTSTRAP_SCAN_ENABLED=true
GMAIL_HISTORY_EXPIRED_FALLBACK_ENABLED=true
# During a fallback scan, suppress per-item Telegram notifications so historical
# mail doesn't burst into the chat.
GMAIL_FALLBACK_SUPPRESS_ITEM_TELEGRAM=true
# Send a single summary message after a fallback/bootstrap scan completes.
GMAIL_FALLBACK_NOTIFY_SUMMARY=true

# ─── Calendar Push (real-time main path, Phase B+) ────────────────────────────
GOOGLE_CALENDAR_ID=primary
CALENDAR_PUSH_ENABLED=true
CALENDAR_WEBHOOK_PATH=/api/calendar/push
# Random secret echoed in X-Goog-Channel-Token. Generate with: openssl rand -hex 32
CALENDAR_CHANNEL_TOKEN=replace_with_random_secret
CALENDAR_WATCH_RENEWAL_CONCURRENCY=3
CALENDAR_BOOTSTRAP_LOOKAHEAD_DAYS=60
CALENDAR_SYNC_TOKEN_EXPIRED_BOOTSTRAP_ENABLED=true

# ─── Private mode (two-person self-use; SaaS-compatible when off) ─────────────
# When true: bypass billing gates and only allow listed users/Telegram IDs.
PRIVATE_MODE=true
# Comma-separated DB user IDs allowed to use push/Telegram features
PRIVATE_ALLOWED_USER_IDS=
# Comma-separated Telegram numeric IDs allowed to bind/use the bot
PRIVATE_ALLOWED_TELEGRAM_IDS=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI / Web Scraping ────────────────────────────────────────────────────────
CAREERPASS_LLM_MODEL=
CAREERPASS_AGENT_DOCS_DIR=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Proactive cron ───────────────────────────────────────────────────────────
PROACTIVE_CRON_DISABLED=false
PROACTIVE_CRON_INTERVAL_MS=
PROACTIVE_CRON_CONCURRENCY=

# ─── Misc ─────────────────────────────────────────────────────────────────────
OWNER_OPEN_ID=
